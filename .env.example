# Copy this file to .env and fill in your values
# Google Cloud service account JSON key (từ Vertex AI console)
GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/your-service-account-key.json

# Gemini model via Vertex AI
# gemini-2.5-flash = recommended (cheap, fast, good vision)
# gemini-2.5-pro   = more accurate but expensive
GEMINI_MODEL=gemini-2.5-flash
VERTEX_LOCATION=us-central1

# Google Cloud project ID (from Vertex AI)
GOOGLE_CLOUD_PROJECT=your-project-id

# PDF conversion DPI (150 = fast, 200 = more accurate for small text)
PDF_DPI=150
